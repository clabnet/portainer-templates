{
  "version": "2",
  "templates": [
    {
      "type": 3,
      "title": "Infrastructure",
      "description": "Infrastructure stack with Homepage dashboard, AdGuard Home for DNS-level ad blocking and filtering, and Nginx Proxy Manager for reverse proxy with SSL management",
      "note": "Uses external network 'horizon_network'. Homepage dashboard on port 3005. AdGuard Home blocks ads at DNS level with web interface on port 8090 and setup wizard on port 3000. Nginx Proxy Manager provides reverse proxy on ports 80/443 with admin UI on port 81.",
      "categories": [
        "Homepage",
        "Networking",
        "Security",
        "DNS",
        "Proxy",
        "Infrastructure"
      ],
      "platform": "linux",
      "logo": "https://ui-avatars.com/api/?name=CB&background=22c55e&color=fff&size=50",
      "name": "infrastructure",
      "repository": {
        "url": "http://github.com/clabnet/portainer-templates",
        "stackfile": "templates/infrastructure/docker-compose.infrastructure.yml"
      },
      "env": [
        {
          "name": "TZ",
          "label": "Timezone",
          "description": "Set your local timezone (e.g., Europe/Rome, America/New_York, Asia/Tokyo)",
          "default": "Europe/Rome"
        },
        {
          "name": "NPM_HTTP_PORT",
          "label": "Nginx Proxy Manager HTTP Port",
          "description": "HTTP port for Nginx Proxy Manager",
          "default": "80"
        },
        {
          "name": "NPM_HTTPS_PORT",
          "label": "Nginx Proxy Manager HTTPS Port",
          "description": "HTTPS port for Nginx Proxy Manager",
          "default": "443"
        },
        {
          "name": "NPM_ADMIN_PORT",
          "label": "Nginx Proxy Manager Admin Port",
          "description": "Admin interface port for Nginx Proxy Manager",
          "default": "81"
        },
        {
          "name": "NPM_DISABLE_IPV6",
          "label": "Nginx Proxy Manager Disable IPv6",
          "description": "Disable IPv6 support (recommended for most home networks)",
          "default": "true",
          "select": [
            {
              "text": "Yes",
              "value": "true"
            },
            {
              "text": "No",
              "value": "false"
            }
          ]
        }
      ],
      "restart_policy": "unless-stopped"
    },
    {
      "type": 3,
      "title": "Database",
      "description": "PostgreSQL 16 database service (with vectorchord/pgvector extensions for Immich) and health checks on port 5433",
      "note": "Uses external network 'horizon_network'. PostgreSQL 16 (ghcr.io/immich-app/postgres image, bundling the vectorchord/pgvector extensions so Immich's smart search can use this instance) with configurable user/password/database via POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB environment variables. Host port defaults to 5433 (5432 is taken by the NAS's own native PostgreSQL instance), override with POSTGRES_PORT.",
      "categories": [
        "Database",
        "Storage",
        "PostgreSQL",
        "MySQL",
        "Redis",
        "Data Management"
      ],
      "platform": "linux",
      "logo": "https://ui-avatars.com/api/?name=CB&background=22c55e&color=fff&size=50",
      "name": "database",
      "repository": {
        "url": "https://github.com/clabnet/portainer-templates",
        "stackfile": "templates/database/docker-compose.database.yml"
      },
      "env": [
        {
          "name": "TZ",
          "label": "Timezone",
          "description": "Set your local timezone for database timestamps and scheduling (e.g., Europe/Rome, America/New_York, Asia/Tokyo)",
          "default": "Europe/Rome"
        },
        {
          "name": "POSTGRES_PORT",
          "label": "PostgreSQL Host Port",
          "description": "Host port for PostgreSQL. Defaults to 5433 because 5432 is taken by the NAS's own native PostgreSQL instance.",
          "default": "5433"
        }
      ],
      "restart_policy": "always"
    },
    {
      "type": 3,
      "title": "Monitoring",
      "description": "Monitoring stack with Uptime Kuma for service monitoring (port 3001), MySpeed for network speed testing (port 5216), Dozzle for real-time Docker logs (port 9999), and Tugtainer for container update notifications (port 9412)",
      "note": "Uses external network 'horizon_network'. Includes uptime monitoring via Uptime Kuma web interface, speed testing via MySpeed, live container logs via Dozzle, and automatic update notifications via Tugtainer.",
      "categories": [
        "Monitoring",
        "Metrics",
        "Logs",
        "Observability",
        "Analytics"
      ],
      "platform": "linux",
      "logo": "https://ui-avatars.com/api/?name=CB&background=22c55e&color=fff&size=50",
      "name": "monitoring",
      "repository": {
        "url": "https://github.com/clabnet/portainer-templates",
        "stackfile": "templates/monitoring/docker-compose.monitoring.yml"
      },
      "env": [
        {
          "name": "TZ",
          "label": "Timezone",
          "description": "Set your local timezone (e.g., Europe/Rome, America/New_York, Asia/Tokyo)",
          "default": "Europe/Rome"
        },
        {
          "name": "DOZZLE_HTTP_PORT",
          "label": "Dozzle HTTP Port",
          "description": "HTTP port for Dozzle log viewer interface",
          "default": "9999"
        }
      ],
      "restart_policy": "always"
    },
    {
      "type": 3,
      "title": "Multimedia",
      "description": "Multimedia stack centered on Immich photo management, using the shared PostgreSQL database and Redis cache",
      "note": "Uses external network 'horizon_network'. Immich provides photo/video backup and management on port 2283 with machine learning capabilities. Uses the shared PostgreSQL instance from the Database stack (deploy that first and create the 'immich' database) plus its own Redis for caching.",
      "categories": [
        "Media",
        "Photos",
        "Videos",
        "Streaming",
        "Multimedia",
        "Entertainment"
      ],
      "platform": "linux",
      "logo": "https://ui-avatars.com/api/?name=CB&background=22c55e&color=fff&size=50",
      "name": "multimedia",
      "repository": {
        "url": "https://github.com/clabnet/portainer-templates",
        "stackfile": "templates/multimedia/docker-compose.multimedia.yml"
      },
      "env": [
        {
          "name": "DB_USERNAME",
          "label": "PostgreSQL Database Username",
          "description": "Username on the shared PostgreSQL instance (Database stack) used by Immich",
          "default": "postgres"
        },
        {
          "name": "DB_PASSWORD",
          "label": "PostgreSQL Database Password",
          "description": "Password for the shared PostgreSQL instance (must match the Database stack's POSTGRES_PASSWORD)",
          "default": "changeme"
        },
        {
          "name": "DB_DATABASE_NAME",
          "label": "Database Name",
          "description": "Name of the database on the shared PostgreSQL instance for Immich - must be created beforehand",
          "default": "immich"
        }
      ],
      "restart_policy": "unless-stopped"
    },
    {
      "type": 3,
      "title": "Home Automation",
      "description": "Home automation stack with Home Assistant for smart home control and Mosquitto MQTT broker for device communication",
      "note": "Uses external network 'horizon_network'. Home Assistant runs on host network mode (port 8123) for device discovery. Mosquitto MQTT broker on ports 1883/9001 for IoT messaging.",
      "categories": [
        "Home Automation",
        "IoT",
        "Smart Home",
        "Assistant",
