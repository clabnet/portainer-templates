      "env": [
        {
          "name": "TZ",
          "label": "Timezone",
          "description": "Set your local timezone for accurate automation scheduling (e.g., Europe/Rome, America/New_York, Asia/Tokyo)",
          "default": "Europe/Rome"
        }
      ],
      "restart_policy": "unless-stopped"
    },
    {
      "type": 3,
      "title": "Tools",
