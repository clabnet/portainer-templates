        },
        {
          "name": "ADGUARD_HTTPS_PORT",
          "label": "AdGuard HTTPS Port",
          "default": "8443"
        },
        {
          "name": "ADGUARD_SETUP_PORT",
          "label": "AdGuard Setup Port",
          "default": "3000"
        }
      ],
      "restart_policy": "unless-stopped"
    },
    {
      "type": 1,
      "title": "Nginx Proxy Manager",
      "name": "nginxpm",
