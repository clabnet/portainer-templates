    {
      "type": 3,
      "title": "Web applications",
      "description": "Web applications stack with Wendy event management platform (backend on port 5454, frontend on port 3454)",
      "note": "Uses external network 'horizon_network'. Wendy provides event management backend and frontend services.",
      "categories": [
        "WEB APP"
      ],
      "platform": "linux",
      "logo": "https://ui-avatars.com/api/?name=CB&background=22c55e&color=fff&size=50",
      "name": "webapp",
      "repository": {
        "url": "https://github.com/clabnet/portainer-templates",
        "stackfile": "templates/webapp/docker-compose.yml"
      },
      "env": [
        {
          "name": "NODE_ENV",
          "label": "Environment",
          "default": "production"
        }
      ],
      "restart_policy": "unless-stopped"
    },
    {
      "type": 1,
      "title": "WENDY backend",
      "name": "wendy-backend",
      "network": "horizon_network",
      "description": "Event management platform with PostgreSQL backend on port 5454 and Nginx frontend on port 3454",
      "categories": [
        "webapp",
        "backend"
      ],
      "platform": "linux",
      "logo": "https://ui-avatars.com/api/?name=CB&background=ff0000&color=fff&size=50",
      "image": "ghcr.io/clabnet/wendy-backend:latest",
      "registry": "ghcr.io",
      "env": [
        {
          "name": "NODE_ENV",
          "label": "Environment",
          "default": "production"
        },
        {
          "name": "HOST",
          "label": "HOST",
          "default": "0.0.0.0"
        },
        {
          "name": "BACKEND_PORT",
          "label": "BACKEND_PORT",
          "default": "5454"
        },
        {
          "name": "POSTGRES_HOST",
          "label": "POSTGRES_HOST",
          "default": "postgres"
        },
        {
          "name": "POSTGRES_PORT",
          "label": "POSTGRES_PORT",
          "default": "5432"
        },
        {
          "name": "POSTGRES_USER",
          "label": "POSTGRES_USER",
          "default": "postgres"
        },
        {
          "name": "POSTGRES_PASSWORD",
          "label": "POSTGRES_PASSWORD",
          "default": "changeme"
        },
        {
          "name": "POSTGRES_DB",
          "label": "POSTGRES_DB",
          "default": "weddingeventsdb"
        },
        {
          "name": "JWT_SECRET_KEY",
          "label": "JWT_SECRET_KEY",
          "default": "xxxxxxxxxx"
        }
      ],
      "restart_policy": "unless-stopped"
    },
    {
      "type": 1,
      "title": "AdGuard Home",
      "name": "adguard",
      "network": "horizon_network",
      "description": "DNS-level ad blocking and filtering with web interface (port 8090) and setup wizard (port 3000)",
      "categories": [
        "Networking",
        "DNS",
        "Security"
      ],
      "platform": "linux",
