IMMICH_VERSION=release
IMMICH_HTTP_PORT=2283

IMMICH_SERVER_URL=https://your-domain.com/api
IMMICH_WEB_URL=https://your-domain.com
IMMICH_EXTERNAL_DOMAIN=https://your-domain.com

# Database - uses the shared postgresql stack (templates/database), not a
# dedicated Immich database. Joins the same horizon_network and connects to
# the "postgresql" container on port 5432.
#
# Before first deploy, create the database on the shared instance, e.g.:
#   docker exec -it postgresql psql -U postgres -c "CREATE DATABASE immich;"
#
# Credentials below must be a user with access to that database - the shared
# postgres superuser (POSTGRES_USER/POSTGRES_PASSWORD from
# templates/database/postgresql/.env) works out of the box.
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_DATABASE_NAME=immich
