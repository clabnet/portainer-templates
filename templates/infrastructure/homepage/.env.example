# Homepage Configuration
HOMEPAGE_HTTP_PORT=3005

# Infrastructure Services
HOMEPAGE_VAR_PORTAINER_URL=http://192.168.1.2:9000
HOMEPAGE_VAR_PORTAINER_API_KEY=your_portainer_api_key

HOMEPAGE_VAR_ADGUARD_URL=http://192.168.1.2:8090
HOMEPAGE_VAR_ADGUARD_USER=admin
HOMEPAGE_VAR_ADGUARD_PWD=your_adguard_password

HOMEPAGE_VAR_NPM_URL=http://192.168.1.2:81
HOMEPAGE_VAR_NPM_EMAIL=admin@example.com
HOMEPAGE_VAR_NPM_PWD=your_npm_password

# Monitoring Services
HOMEPAGE_VAR_UPTIME_KUMA_URL=http://192.168.1.2:3001

HOMEPAGE_VAR_MYSPEED_URL=http://192.168.1.2:5216

HOMEPAGE_VAR_TUGTAINER_URL=http://192.168.1.2:9412

# Multimedia Services
HOMEPAGE_VAR_IMMICH_URL=https://photo.clabnet.com
HOMEPAGE_VAR_IMMICH_API_KEY=your_immich_api_key

HOMEPAGE_VAR_JELLYFIN_URL=http://192.168.1.2:8096
HOMEPAGE_VAR_JELLYFIN_API_KEY=your_jellyfin_api_key

# Home Automation
HOMEPAGE_VAR_HOME_ASSISTANT_URL=http://192.168.1.2:8123
HOMEPAGE_VAR_HOME_ASSISTANT_API_KEY=your_home_assistant_api_key

# Other Services
HOMEPAGE_VAR_DOZZLE_URL=http://192.168.1.2:9999

# Calendar (optional)
# HOMEPAGE_VAR_CALENDAR_URL=your_calendar_url
# HOMEPAGE_VAR_CALENDAR_ICAL=your_ical_url
